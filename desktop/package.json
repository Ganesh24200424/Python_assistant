{
  "name": "jarvis-desktop",
  "version": "1.0.0",
  "description": "J.A.R.V.I.S Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.jarvis.desktop",
    "productName": "Jarvis",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "Frontend/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "Frontend/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  }
}